# Example nginx site config for veriagent.dimikog.org
#
# Prefer CORS in FastAPI (backend/app/main.py). Use this snippet only if you
# need an edge stopgap before restarting uvicorn with CORSMiddleware enabled.
# Do not enable both nginx and FastAPI CORS — duplicate headers break browsers.

map $http_origin $veriagent_cors_origin {
    default "";
    "https://dimikog.github.io" "https://dimikog.github.io";
    "http://localhost:5173"     "http://localhost:5173";
    "http://127.0.0.1:5173"     "http://127.0.0.1:5173";
}

server {
    listen 443 ssl http2;
    server_name veriagent.dimikog.org;

    # ssl_certificate ...;
    # ssl_certificate_key ...;

    location / {
        if ($request_method = OPTIONS) {
            add_header Access-Control-Allow-Origin $veriagent_cors_origin;
            add_header Access-Control-Allow-Methods "GET, POST, OPTIONS";
            add_header Access-Control-Allow-Headers "*";
            add_header Access-Control-Max-Age 600;
            add_header Content-Length 0;
            return 204;
        }

        add_header Access-Control-Allow-Origin $veriagent_cors_origin always;
        add_header Vary Origin always;

        proxy_pass http://127.0.0.1:8000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
